import os

for dirname, _, filenames in os.walk('/kaggle/input'):
    for filename in filenames:
        print(os.path.join(dirname, filename))


import pandas as pd

swift_df = pd.read_csv('/kaggle/input/datasets/ladkevinkumar/group9-dsb/swift_currency_tracker_all_reports.csv')

swift_df['data_month'] = pd.to_datetime(
    swift_df['data_month'],
    errors='coerce'
)

latest_month = swift_df['data_month'].max()

latest_data = swift_df[
    swift_df['data_month'] == latest_month
]

cny_data = latest_data[
    latest_data['currency_or_economy'].astype(str).str.contains(
        'CNY|RMB|Renminbi|Yuan|China',
        case=False,
        na=False
    )
][[
    'data_month',
    'currency_or_economy',
    'value',
    'rmb_global_rank'
]]

cny_data.columns = [
    'Latest_Month',
    'Currency',
    'Global_Payment_Share',
    'Global_Rank'
]

cny_data['Latest_Month'] = cny_data['Latest_Month'].dt.strftime('%Y-%m')

cny_data = cny_data.dropna(how='all')
cny_data = cny_data.drop_duplicates()

cny_data.to_csv(
    'cny_rmb_latest_global_payment.csv',
    index=False
)

print(cny_data)

print("\nAvailable Currency Names:")
print(
    latest_data['currency_or_economy']
    .drop_duplicates()
    .sort_values()
    .tolist()
)
